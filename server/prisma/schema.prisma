// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id String @id @default(cuid())
    username String
    walletAddress String @unique
    createdAt DateTime @default(now())
    /// True once this user has clicked "Check now" AND their wallet was confirmed on-chain.
    /// Gates whether their creator-side fee share is included in investor swaps. Platform fee
    /// always pays regardless — our wallet is always live.
    feeReceiverVerified Boolean @default(false)
    /// When the last successful verification ran. Helpful for re-verify UX and audit.
    feeReceiverVerifiedAt DateTime?
    buckets Bucket[]
    history History[]
    deposits Deposit[]
    withdrawals Withdrawal[]
    basketAttempts BasketAttempt[]
}

model Deposit {
    id String @id @default(cuid())
    bucketId String
    userId String
    bucket Bucket @relation(references: [id], fields: [bucketId])
    user User @relation(references: [id], fields: [userId])
    /// Net USDC (or unit) credited to the bucket TVL after protocol fee.
    amount Decimal
    feeCreator Decimal @default(0)
    feePlatform Decimal @default(0)
    /// Set when invest is confirmed on-chain (SOL transfer to treasury).
    transactionSignature String? @unique
    /// Jupiter basket invest: all swap tx signatures (same order as plan legs).
    jupiterLegSignatures Json?
    createdAt DateTime @default(now())
}

model Withdrawal {
    id String @id @default(cuid())
    bucketId String
    userId String
    bucket Bucket @relation(references: [id], fields: [bucketId])
    user User @relation(references: [id], fields: [userId])
    amount Decimal
    /// First sell-leg signature when sell goes through Jupiter (mainnet); null for ledger-only withdrawals.
    transactionSignature String? @unique
    /// All Jupiter sell leg signatures, in plan order.
    jupiterLegSignatures Json?
    createdAt DateTime @default(now())

    @@map("Withdawal")
}

model History {
    id String @id @default(cuid())
    userId String
    user User @relation(references: [id], fields: [userId])
    purchaseDate DateTime // have to complete it
}

model Asset {
    id String @id @unique
    name String
    symbol String
    iconUrl String
    decimals Int @default(9)
    category String @default("token")
    inCatalog Boolean @default(false)
    /// Jupiter Tokens v2 — true if Jupiter has the token on its verified/strict list.
    isVerified Boolean @default(false)
    /// Derived from Jupiter audit fields (mint auth on, freeze auth on, top holder concentration).
    isSus Boolean @default(false)
    /// Jupiter organic activity score, 0–100.
    organicScore Float?
    /// Jupiter's bucket label for organicScore: "high" / "medium" / "low".
    organicScoreLabel String?
    /// Jupiter tags ("verified", "strict", "lst", etc.) — stored verbatim for filtering / future use.
    tags Json?
    /// When the row was last reconciled against Jupiter Tokens v2.
    lastSyncedAt DateTime?
    listing Listing[]
    @@index([inCatalog, category])
}

model Listing {
    id String @id @default(cuid())
    bucketId String
    assetId String
    percentage Decimal?
    bucket Bucket @relation(references: [id], fields: [bucketId])
    asset Asset @relation(references: [id], fields: [assetId])
}

model Bucket {
    id String @id @default(cuid())
    name String 
    version Int @default(0)
    creatorId String
    creator User @relation(references: [id], fields: [creatorId])
    listing Listing[]
    tvl Decimal
    apy Decimal?
    estimated_apy Decimal
    type BucketType @default(DRAFT)
    metaData Json?
    researchDoc String?
    createdAt DateTime @default(now())
    deposits Deposit[]
    withdrawals Withdrawal[]
    basketAttempts BasketAttempt[]
    @@unique([creatorId, name, version])
}

enum BucketType {
    DRAFT
    PUBLISHED
}

/// A basket buy or sell intent. Tracks per-leg outcome so partial fills don't lie about TVL,
/// and lets the user resume only the missing legs later.
model BasketAttempt {
    id String @id @default(cuid())
    bucketId String
    userId String
    bucket Bucket @relation(references: [id], fields: [bucketId])
    user User @relation(references: [id], fields: [userId])
    direction BasketDirection
    intendedSol Decimal
    slippageBps Int
    status BasketAttemptStatus @default(PENDING)
    abandonedAt DateTime?
    feeTransferSignature String?
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt
    legs BasketAttemptLeg[]

    @@index([userId, status])
    @@index([bucketId])
}

model BasketAttemptLeg {
    id String @id @default(cuid())
    attemptId String
    attempt BasketAttempt @relation(references: [id], fields: [attemptId], onDelete: Cascade)
    mint String
    symbol String?
    lamports Decimal
    legIndex Int
    status BasketLegStatus @default(PENDING)
    transactionSignature String? @unique
    lastError String?
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt

    @@index([attemptId])
    @@index([status])
}

enum BasketDirection {
    BUY
    SELL
}

enum BasketAttemptStatus {
    PENDING
    PARTIAL
    COMPLETE
    ABANDONED
}

enum BasketLegStatus {
    PENDING
    SUCCESS
    FAILED
    SKIPPED
}

model Nonce {
    id String @id @default(cuid())
    walletAddress String
    value String
    used Boolean
    expiresAt DateTime // expiresAt: new Date(Date.now() + 5 * 60 * 1000) 
    createdAt DateTime @default(now())
}