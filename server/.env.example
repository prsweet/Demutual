DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/demutual"
JWT_SECRET="change-me"

# HTTP (optional)
# PORT=3000
# CORS_ORIGINS=https://app.example.com,http://localhost:5173

# Network mode: "mainnet" (default) or "devnet".
# devnet  -> SOL→treasury buys + ledger sells. Jupiter buy/sell endpoints return JUPITER_NOT_AVAILABLE_ON_DEVNET.
# mainnet -> All flows: SOL→treasury, Jupiter buy basket, Jupiter sell basket (ExactOut).
DEMUTUAL_NETWORK="mainnet"

# On-chain treasury invest (used by /buckets/:id/invest on both networks).
# For devnet demos, point SOLANA_RPC_URL at devnet and use a devnet wallet.
SOLANA_RPC_URL="https://api.devnet.solana.com"
INVEST_TREASURY_PUBKEY="YourWalletAddressBase58"

# Optional: Jupiter API (defaults to https://quote-api.jup.ag) — mainnet routes only.
# JUPITER_API_KEY=
# JUPITER_API_HOST=https://quote-api.jup.ag

# Fee splits on Jupiter buy/sell. Each is in basis points of gross SOL (10 = 0.10%).
# Investor signs ONE tx that bundles both transfers, the server verifies both on-chain.
# - Platform fee active when PLATFORM_FEE_BPS > 0 AND PLATFORM_FEE_WALLET_PUBKEY is set.
# - Creator fee active when CREATOR_FEE_BPS > 0 AND the bucket creator has a walletAddress
#   (set automatically at signup; no env var needed for which wallet).
# Max enforced server-side per fee: 1500 (15%).
# PLATFORM_FEE_BPS=10
# PLATFORM_FEE_WALLET_PUBKEY="YourPlatformFeeWalletBase58"
# CREATOR_FEE_BPS=10
