# Backend API base URL (no trailing slash). Must match a CORS origin allowed by the server
# (see server CORS_ORIGINS or default localhost regexes).
BUN_PUBLIC_API_URL=http://localhost:3000

# RPC for devnet treasury invest + tx confirmation (match DEMUTUAL_NETWORK on the server).
BUN_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# RPC for Jupiter swap submission when the API is in mainnet + jupiterEnabled mode.
BUN_PUBLIC_SOLANA_JUPITER_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: treasury pubkey for POST /buckets/:id/invest if not returned by GET /
# BUN_PUBLIC_INVEST_TREASURY_PUBKEY=
